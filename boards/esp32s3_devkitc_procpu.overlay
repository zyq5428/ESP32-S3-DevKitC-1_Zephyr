/* esp32s3_devkitc_procpu.overlay */

/* 直接包含适配 16MB Flash + 8MB PSRAM 的定义 */
// #include <espressif/esp32s3/esp32s3_wroom_n16r8.dtsi>

/* 包含必要的头文件，这些头文件里定义了硬件信号 ID */
#include <espressif/esp32s3/esp32s3_common.dtsi>
#include <zephyr/dt-bindings/pinctrl/esp32s3-pinctrl.h>
#include <zephyr/dt-bindings/pinctrl/esp32s3-gpio-sigmap.h>
#include <zephyr/dt-bindings/led/led.h>

/*
 * ESP32-S3 外部 32MB 八线 Flash (经典 Swap 模式) 分区表覆盖定义
 * 通过精准标签引用 (&)，直接强行重写物理区间，100% 避免 Label 重复冲突
 */

&flash0 {
	/* 1. 锁死外部物理 Flash 总大小为 32MB (十六进制上限 0x2000000) */
	reg = <0x0 DT_SIZE_M(32)>;
};

/* =======================================================
 * 2. 基础引导与系统分区重写 (0MB ~ 0.125MB)
 * ======================================================= */
&boot_partition {
	reg = < 0x00000000 0x00010000 >; /* MCUboot 二级引导：占 64KB */
};

&sys_partition {
	reg = < 0x00010000 0x00010000 >; /* 系统保留：占 64KB */
};

/* =======================================================
 * PROCPU (主核) 双槽 OTA 空间重写 (0.125MB ~ 12.125MB)
 * 单槽分配 6MB (0x600000 字节)，两槽完全等大，满足 Swap 铁律
 * ======================================================= */
&slot0_partition {
	reg = < 0x00020000 0x00600000 >; /* Slot 0: 主核运行区 (0x20000 ~ 0x620000) */
};

&slot1_partition {
	reg = < 0x00620000 0x00600000 >; /* Slot 1: 主核 OTA 备份区 (0x620000 ~ 0xC20000) */
};

/* =======================================================
 * APPCPU (副核) 双槽 AMP 空间重写 (12.125MB ~ 16.125MB)
 * 单槽分配 2MB (0x200000 字节)
 * ======================================================= */
&slot0_appcpu_partition {
	reg = < 0x00c20000 0x00200000 >; /* 副核当前运行区 (0xC20000 ~ 0xE20000) */
};

&slot1_appcpu_partition {
	reg = < 0x00e20000 0x00200000 >; /* 副核 OTA 备份区 (0xE20000 ~ 0x1020000) */
};

/* =======================================================
 * LPCORE (低功耗微核) 空间重写 (16.125MB ~ 16.25MB)
 * 单槽分配 64KB (0x10000 字节)
 * ======================================================= */
&slot0_lpcore_partition {
	reg = < 0x01020000 0x00010000 >;
};

&slot1_lpcore_partition {
	reg = < 0x01030000 0x00010000 >;
};

/* =======================================================
 * 剩余所有大平层空间重写：分配给存储区与调试 (16.3125MB ~ 32MB)
 * ======================================================= */
&storage_partition {
	reg = < 0x01040000 0x00f90000 >; /* Storage: 分配约 15.6MB 给文件系统 */
};

/* =======================================================
 * 🌟 Swap 必备的中转站暂存区重写
 * ======================================================= */
&scratch_partition {
	reg = < 0x01fd0000 0x00010000 >; /* 分配固定的 64KB 用于搬运数据 */
};

&coredump_partition {
	/* 起始地址 0x01FE0000 + 大小 128KB (0x20000) = 0x02000000 (完美撞线 32MB 终点) */
	reg = < 0x01fe0000 0x00020000 >; 
};

/*
 * ESP32-S3 外部 16MB 八线 PSRAM
 */
&psram0 {
	size = <DT_SIZE_M(16)>;
};

/ {
    chosen {
        /* 核心：告诉 Zephyr 用哪个串口跑 Shell */
        zephyr,shell-uart = &uart1;
        zephyr,console = &uart1;
    };

    aliases {
        led-strip = &led_strip;
    };

    // leds {
    //     compatible = "gpio-leds";
    //     test_gpio38: led_0 {
    //         /* GPIO38 在 Zephyr ESP32 映射中通常属于 gpio1 的第 6 号引脚 (32 + 6 = 38) */
    //         gpios = <&gpio1 6 GPIO_ACTIVE_HIGH>;
    //         label = "Test GPIO38";
    //     };
    // };
};

/* 引脚复用配置：将 GPIO38 映射为 SPI3 的数据输出信号 (ID 68) */
&pinctrl {
    spim3_ws2812_default: spim3_ws2812_default {
        group1 {
            /* * ESP32_PINMUX(1, 6, 68) 的含义：
             * 1: GPIO 分组 1 (引脚 32-53)
             * 6: 组内索引 6 (32 + 6 = 38)
             * 68: SPI3_D_OUT (MOSI) 的信号 ID
             */
            pinmux = <ESP32_PINMUX(1, 6, 68)>;
            /* 核心修正：显式开启输出使能，并关闭偏置电阻 */
            output-enable;
            bias-disable;
        };
    };
};

/* 确保 uart0 节点是启用状态 */
&uart0 {
    status = "okay";
    current-speed = <115200>;
};

&uart1 {
	status = "okay";
	current-speed = <115200>;
	pinctrl-0 = <&uart1_default>;
	pinctrl-names = "default";
};

&i2s0_default {
	group1 {
		pinmux = <I2S0_O_SD_GPIO38>;
	};
};

i2s_led: &i2s0 {
	status = "okay";

	dmas = <&dma 3>;
	dma-names = "tx";

	led_strip: ws2812@0 {
		compatible = "worldsemi,ws2812-i2s";

		reg = <0>;
		chain-length = <1>;
		color-mapping = <LED_COLOR_ID_GREEN
				        LED_COLOR_ID_RED
				        LED_COLOR_ID_BLUE>;
		reset-delay = <500>;
	};
};

&dma {
	status = "okay";
};

&wifi {
    status = "okay";
};

&esp32_bt_hci {
    status = "okay";
};

&trng0 {
    status = "okay";
};