/* esp32s3_devkitc_procpu.overlay */

/* 直接包含适配 16MB Flash + 8MB PSRAM 的定义 */
// #include <espressif/esp32s3/esp32s3_wroom_n16r8.dtsi>

/* 包含必要的头文件，这些头文件里定义了硬件信号 ID */
#include <espressif/esp32s3/esp32s3_common.dtsi>
#include <zephyr/dt-bindings/pinctrl/esp32s3-pinctrl.h>
#include <zephyr/dt-bindings/pinctrl/esp32s3-gpio-sigmap.h>
#include <zephyr/dt-bindings/led/led.h>

/* 自定义 Flash + PSRAM 的大小 */
/* 32MB flash */
&flash0 {
	reg = <0x0 DT_SIZE_M(32)>;
};

/* 16MB psram */
&psram0 {
	size = <DT_SIZE_M(16)>;
};

/ {
    chosen {
        /* 核心：告诉 Zephyr 用哪个串口跑 Shell */
        zephyr,shell-uart = &uart1;
        zephyr,console = &uart1;
    };

    aliases {
        led-strip = &led_strip;
    };

    // leds {
    //     compatible = "gpio-leds";
    //     test_gpio38: led_0 {
    //         /* GPIO38 在 Zephyr ESP32 映射中通常属于 gpio1 的第 6 号引脚 (32 + 6 = 38) */
    //         gpios = <&gpio1 6 GPIO_ACTIVE_HIGH>;
    //         label = "Test GPIO38";
    //     };
    // };
};

/* 引脚复用配置：将 GPIO38 映射为 SPI3 的数据输出信号 (ID 68) */
&pinctrl {
    spim3_ws2812_default: spim3_ws2812_default {
        group1 {
            /* * ESP32_PINMUX(1, 6, 68) 的含义：
             * 1: GPIO 分组 1 (引脚 32-53)
             * 6: 组内索引 6 (32 + 6 = 38)
             * 68: SPI3_D_OUT (MOSI) 的信号 ID
             */
            pinmux = <ESP32_PINMUX(1, 6, 68)>;
            /* 核心修正：显式开启输出使能，并关闭偏置电阻 */
            output-enable;
            bias-disable;
        };
    };
};

/* 确保 uart0 节点是启用状态 */
&uart0 {
    status = "okay";
    current-speed = <115200>;
};

&uart1 {
	status = "okay";
	current-speed = <115200>;
	pinctrl-0 = <&uart1_default>;
	pinctrl-names = "default";
};

&i2s0_default {
	group1 {
		pinmux = <I2S0_O_SD_GPIO38>;
	};
};

i2s_led: &i2s0 {
	status = "okay";

	dmas = <&dma 3>;
	dma-names = "tx";

	led_strip: ws2812@0 {
		compatible = "worldsemi,ws2812-i2s";

		reg = <0>;
		chain-length = <1>;
		color-mapping = <LED_COLOR_ID_GREEN
				        LED_COLOR_ID_RED
				        LED_COLOR_ID_BLUE>;
		reset-delay = <500>;
	};
};

&dma {
	status = "okay";
};

&wifi {
    status = "okay";
};

&esp32_bt_hci {
    status = "okay";
};

&trng0 {
    status = "okay";
};