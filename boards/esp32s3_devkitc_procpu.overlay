/* esp32s3_devkitc_procpu.overlay */

/* 包含必要的头文件，这些头文件里定义了硬件信号 ID */
#include <espressif/esp32s3/esp32s3_common.dtsi>
#include <zephyr/dt-bindings/pinctrl/esp32s3-pinctrl.h>
#include <zephyr/dt-bindings/pinctrl/esp32s3-gpio-sigmap.h>
#include <zephyr/dt-bindings/led/led.h>
/* [LCD] 引入 MIPI DBI 和显示面板的 DT 常量定义 */
#include <zephyr/dt-bindings/mipi_dbi/mipi_dbi.h>
#include <zephyr/dt-bindings/display/panel.h>
/* [PWM] 引入 PWM 宏定义 (PWM_HZ, PWM_POLARITY_NORMAL 等) */
#include <zephyr/dt-bindings/pwm/pwm.h>

/*
 * ESP32-S3 外部 32MB 八线 Flash (经典 Swap 模式) 分区表覆盖定义
 * 通过精准标签引用 (&)，直接强行重写物理区间，100% 避免 Label 重复冲突
 */
&flash0 {
    /* 1. 锁死外部物理 Flash 总大小为 32MB (十六进制上限 0x2000000) */
    reg = <0x0 DT_SIZE_M(32)>;

    /* 2. 深入到 partitions 容器内部，通过路径覆盖将地址与节点名一字不差地绑死 */
    partitions {
        compatible = "fixed-partitions";
        #address-cells = <0x1>;
        #size-cells = <0x1>;

		/* 🌟 核心杀招：使用绝对路径或节点名，彻底将官方旧定义里的“不合规节点”物理蒸发！ */
		/delete-node/ partition@0;
		/delete-node/ partition@10000;
		/delete-node/ partition@20000;
		/delete-node/ partition@170000;
		/delete-node/ partition@2c0000;
		/delete-node/ partition@330000;
		/delete-node/ partition@3a0000;
		/delete-node/ partition@3a8000;
		/delete-node/ partition@3b0000;
		/delete-node/ partition@3e0000;
		/delete-node/ partition@3ff000;

        /* 1. MCUboot 引导程序区：系统启动的第一跳，负责校验和加载固件 */
        boot_partition: partition@0 {
            label = "mcuboot";
            reg = <0x0 DT_SIZE_K(64)>; /* 占用 64KB */
        };

        /* 2. 系统保留区：可能用于存放分区表索引、系统标志位或必要的硬件配置参数 */
        sys_partition: partition@10000 {
            label = "sys";
            reg = <0x10000 DT_SIZE_K(64)>; /* 占用 64KB */
        };

        /* 3. 主核心 (ProCPU) 的主程序区 (Slot 0) */
        slot0_partition: partition@20000 {
            label = "image-0";
            reg = <0x20000 DT_SIZE_K(12096)>; /* 约 11.8MB */
        };

        /* 4. 主核心 (ProCPU) 的升级备份区 (Slot 1) */
        slot1_partition: partition@bf0000 {
            label = "image-1";
            reg = <0xbf0000 DT_SIZE_K(12096)>; /* 大小与 Slot 0 必须对称 */
        };

        /* 5. AppCPU (副核心) 的主程序区 */
        slot0_appcpu_partition: partition@17c0000 {
            label = "image-0-appcpu";
            reg = <0x17c0000 DT_SIZE_K(4032)>; /* 约 3.9MB */
        };

        /* 6. AppCPU (副核心) 的升级备份区 */
        slot1_appcpu_partition: partition@1bb0000 {
            label = "image-1-appcpu";
            reg = <0x1bb0000 DT_SIZE_K(4032)>;
        };

        /* 7. LP-Core (低功耗核心) 的主程序区 */
        slot0_lpcore_partition: partition@1fa0000 {
            label = "image-0-lpcore";
            reg = <0x1fa0000 DT_SIZE_K(32)>; /* 32KB，通常用于超轻量级代码 */
        };

        /* 8. LP-Core (低功耗核心) 的升级备份区 */
        slot1_lpcore_partition: partition@1fa8000 {
            label = "image-1-lpcore";
            reg = <0x1fa8000 DT_SIZE_K(32)>;
        };

        /* 9. 数据存储区：用于存放文件系统 (如 LittleFS/FATFS) 或 NVS 参数 */
        storage_partition: partition@1fb0000 {
            label = "storage";
            reg = <0x1fb0000 DT_SIZE_K(192)>; /* 192KB */
        };

        /* 10. 临时交换区：OTA 升级过程中，MCUboot 使用该区域进行镜像搬运/恢复 */
        scratch_partition: partition@1fe0000 {
            label = "image-scratch";
            reg = <0x1fe0000 DT_SIZE_K(124)>; /* 124KB */
        };

        /* 11. 崩溃转储区：系统发生异常 (Panic/Crash) 时保存现场信息 */
        coredump_partition: partition@1fff000 {
            label = "coredump";
            reg = <0x1fff000 DT_SIZE_K(4)>; /* 4KB，用于存核心寄存器快照 */
        };
    };
};

/*
 * ESP32-S3 外部 16MB 八线 PSRAM
 */
&psram0 {
	size = <DT_SIZE_M(16)>;
};

/ {
    chosen {
        /* 核心：告诉 Zephyr 用哪个串口跑 Shell */
        zephyr,shell-uart = &uart1;
        zephyr,console = &uart1;
        /* 核心：告诉 LVGL 用哪个显示设备 */
        zephyr,display = &st7789v;
    };

    aliases {
        led-strip = &led_strip;
        /* [PWM 背光] 通过别名让 C 代码用 PWM_DT_SPEC_GET 获取 PWM 设备 */
        pwm-backlight = &pwm_bl;
    };

    /*
     * [LCD 显示] ST7789V SPI 显示屏 (240x280) 配置
     * 通过 MIPI DBI SPI 框架驱动
     *
     * 硬件接线:
     *   SCLK → GPIO12, MOSI → GPIO11, CS → GPIO10
     *   DC   → GPIO8,  RST  → GPIO9
     *   BLK  → GPIO4 (背光 PWM)
     *   VCC  → 3.3V,   GND  → GND
     *
     * 注意事项:
     *   - DC 引脚: 高电平=数据, 低电平=命令
     *   - RST 引脚: 低电平复位 (GPIO_ACTIVE_LOW)
     *   - write-only 表示只写不读，节省引脚和代码
     *   - y-offset = 20: 因为 ST7789 内部 RAM 是 240x320,
     *     240x280 的显示区域需要垂直偏移居中
     */
    mipi_dbi {
        compatible = "zephyr,mipi-dbi-spi";
        /*
         * [SPI 总线] 使用 ESP32-S3 的 FSPI (SPI2)
         * 默认引脚: CS=GPIO10, MOSI=GPIO11, SCLK=GPIO12
         * 不需要 MISO (只写模式)
         */
        spi-dev = <&spi2>;
        /*
         * [DC 引脚] 数据/命令选择线
         * gpio0 表示 GPIO 控制器 0 (管理 GPIO0~GPIO31)
         * 8 表示 GPIO8
         * GPIO_ACTIVE_HIGH: 高电平传输数据，低电平传输命令
         */
        dc-gpios = <&gpio0 8 GPIO_ACTIVE_HIGH>;
        /*
         * [RST 引脚] 硬件复位线
         * GPIO_ACTIVE_LOW: 低电平触发复位，正常工作为高电平
         */
        reset-gpios = <&gpio0 9 GPIO_ACTIVE_LOW>;
        /* [只写模式] ST7789 不需要读回像素数据，设为只写优化性能 */
        write-only;
        #address-cells = <1>;
        #size-cells = <0>;

        /*
         * [ST7789V 显示面板子节点]
         * compatible = "sitronix,st7789v" 匹配 Zephyr 内置驱动
         * reg = <0>: 使用 SPI CS0 (GPIO10)
         */
        st7789v: st7789v@0 {
            compatible = "sitronix,st7789v";
            reg = <0>;
            /*
             * [SPI 时钟] 20MHz
             * ST7789 数据手册支持最高 62.5MHz (写周期)
             * 使用 20MHz 是稳定可靠的选择，线太长可降至 10MHz
             */
            /*
             * [SPI 时钟] 40MHz (性能优化)
             * ST7789 写周期最小 66ns (约 15MHz 理论值)
             * 实测 40MHz 稳定运行，画面流畅无撕裂
             * 如果画面花屏/闪屏，降回 20MHz
             */
            mipi-max-frequency = <40000000>;
            /*
             * [SPI 模式] 4 线模式:
             *   - CS:  片选 (GPIO10)
             *   - DC:  数据/命令 (GPIO8)
             *   - SCLK: 时钟 (GPIO12)
             *   - MOSI: 数据 (GPIO11)
             * 3 线模式只用 3 根线 (DC 复用)，4 线更稳定
             */
            mipi-mode = "MIPI_DBI_MODE_SPI_4WIRE";
            /* [分辨率] 240x280 像素 */
            width = <240>;
            height = <280>;
            /* [水平偏移] 通常从 0 开始 */
            x-offset = <0>;
            /*
             * [垂直偏移] ST7789 内部 GRAM 是 240x320
             * 对于 240x280 的物理面板，显示区域通常需要偏移
             * y-offset = (320 - 280) / 2 = 20 像素居中
             * 如果画面上下有错位，请调整这个值
             */
            y-offset = <20>;
            /*
             * [像素格式] RGB565 (16 位色)
             * R:5bit G:6bit B:5bit = 共 16 位 = 2 字节/像素
             * 这是 ST7789 最常用的格式，也是 LVGL 默认格式
             */
            pixel-format = <PANEL_PIXEL_FORMAT_RGB_565>;
            /* ===== 以下为 ST7789 初始化时序参数 ===== */
            /* 这些参数来自 ST7789V 数据手册的推荐值 */
            /* ===== 以下面板时序参数来自 Pandora 已验证配置 ===== */
            vcom = <0x3F>;                    /* VCOM 电压 (pandora 值) */
            gctrl = <0x05>;                   /* 门极控制 (pandora 值) */
            vrhs = <0x0F>;                    /* VRH 设置 (pandora 值) */
            vdvs = <0x20>;                    /* VDV 设置 */
            mdac = <0x00>;                    /* MADCTL: 默认扫描方向 */
            gamma = <0x01>;                   /* Gamma 曲线选择 */
            lcm = <0x2c>;                     /* LCM 控制 */
            porch-param = [0c 0c 00 33 33];   /* 前后廊参数 (5 字节) */
            cmd2en-param = [5a 69 02 01];     /* Command2 使能参数 (4 字节) */
            pwctrl1-param = [a4 a1];          /* 电源控制 1 (2 字节) */
            pvgam-param = [D0 05 09 09 08 14 28 33 3F 07 13 14 28 30]; /* 正极性 Gamma (pandora 值) */
            nvgam-param = [D0 05 09 09 08 03 24 32 32 3B 14 13 28 2F]; /* 负极性 Gamma (pandora 值) */
            ram-param = [00 f0];              /* RAM 控制参数 (2 字节) */
            rgb-param = [cd 08 14];           /* RGB 接口控制参数 (3 字节) */
        };
    };

    /*
     * [PWM 背光] LEDC PWM 控制 GPIO4 → LCD BLK
     *
     * 使用 ESP32-S3 的 LEDC 控制器，通道 0，定时器 0
     * PWM_HZ(250): 250Hz 频率 (周期 4ms)，高于人眼闪烁感知阈值 (~50Hz)
     *               低频 PWM 可以减少 EMI 同时保持无闪烁感
     * PWM_POLARITY_NORMAL: 高电平点亮背光
     *
     * 对应 C 代码中:
     *   PWM_DT_SPEC_GET(DT_ALIAS(pwm_backlight))
     *   返回 &ledc0 通道 0 的 PWM 规格，用于 pwm_set_pulse_dt()
     */
    pwmleds {
        compatible = "pwm-leds";
        status = "okay";

        pwm_bl: pwm_bl {
            pwms = <&ledc0 0 PWM_HZ(250) PWM_POLARITY_NORMAL>;
            label = "pwm_backlight";
        };
    };

    // leds {
    //     compatible = "gpio-leds";
    //     test_gpio38: led_0 {
    //         /* GPIO38 在 Zephyr ESP32 映射中通常属于 gpio1 的第 6 号引脚 (32 + 6 = 38) */
    //         gpios = <&gpio1 6 GPIO_ACTIVE_HIGH>;
    //         label = "Test GPIO38";
    //     };
    // };
};

/*
 * [LEDC 背光引脚复用] 将 GPIO4 映射为 LEDC 通道 0 的 PWM 输出
 *
 * LEDC_CH0_GPIO4 的定义位于:
 *   zephyr/include/zephyr/dt-bindings/pinctrl/esp32s3-pinctrl.h
 *   #define LEDC_CH0_GPIO4 ESP32_PINMUX(4, ESP_NOSIG, ESP_LEDC_LS_SIG_OUT0)
 *
 * output-enable: GPIO4 设为推挽输出模式
 */
&pinctrl {
    ledc0_default: ledc0_default {
        group1 {
            pinmux = <LEDC_CH0_GPIO4>;
            output-enable;
        };
    };
};

/* 确保 uart0 节点是启用状态 */
&uart0 {
    status = "okay";
    current-speed = <115200>;
};

&uart1 {
	status = "okay";
	current-speed = <115200>;
	pinctrl-0 = <&uart1_default>;
	pinctrl-names = "default";
};

&i2s0_default {
	group1 {
		pinmux = <I2S0_O_SD_GPIO38>;
	};
};

i2s_led: &i2s0 {
	status = "okay";

	dmas = <&dma 3>;
	dma-names = "tx";

	led_strip: ws2812@0 {
		compatible = "worldsemi,ws2812-i2s";

		reg = <0>;
		chain-length = <1>;
		color-mapping = <LED_COLOR_ID_GREEN
				        LED_COLOR_ID_RED
				        LED_COLOR_ID_BLUE>;
		reset-delay = <500>;
	};
};

&dma {
	status = "okay";
};

&wifi {
    status = "okay";
};

&esp32_bt_hci {
    status = "okay";
};

&trng0 {
    status = "okay";
};

/*
 * [SPI2] FSPI 总线 — 用于驱动 ST7789 LCD
 * 使用默认引脚映射:
 *   CS   = GPIO10 (FSPICS0)
 *   MOSI = GPIO11 (FSPID)
 *   SCLK = GPIO12 (FSPICLK)
 *   MISO = GPIO13 (FSPIQ) — LCD 是只写的，这个引脚实际未使用
 */
&spi2 {
    status = "okay";
    pinctrl-0 = <&spim2_default>;
    pinctrl-names = "default";
};

/*
 * [LEDC PWM 控制器] ESP32-S3 的 LED 控制模块
 *
 * 配置说明:
 *   - 通道 0 (channel0@0): 绑定到 GPIO4，用于 LCD 背光调光
 *   - timer = <0>: 使用定时器 0 作为时钟源
 *     LEDC 有 4 个独立定时器 (0~3)，每个定时器可以有不同频率
 *
 * 使用方式 (C 代码):
 *   const struct pwm_dt_spec pwm_bl =
 *       PWM_DT_SPEC_GET(DT_ALIAS(pwm_backlight));
 *   pwm_set_pulse_dt(&pwm_bl, duty_ns);  // 设置占空比
 */
&ledc0 {
    status = "okay";
    pinctrl-0 = <&ledc0_default>;
    pinctrl-names = "default";
    #address-cells = <1>;
    #size-cells = <0>;

    /*
     * [通道 0] LEDC 通道 0 — 输出到 GPIO4
     * reg = <0x0>: 通道号 (必须匹配 pinctrl 中的 LEDC_CH0_GPIO4)
     * timer = <0>: 使用定时器 0 (0~3)
     */
    channel0@0 {
        reg = <0x0>;
        timer = <0>;
    };
};