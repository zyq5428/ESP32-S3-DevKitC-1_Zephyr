CONFIG_SHELL_AUTOSTART=y
CONFIG_SHELL_CMDS_RETURN_VALUE=y
# CONFIG_SHELL_CUSTOM_HEADER is not set
CONFIG_SHELL_TX_TIMEOUT_MS=500
CONFIG_SHELL_BYPASS_READ_BUF_SIZE=16
CONFIG_DEVICE_SHELL=y
CONFIG_DEVICE_SHELL_INIT_CMD=y
CONFIG_DATE_SHELL=y
CONFIG_DEVMEM_SHELL=y
# CONFIG_ZYCLICTEST_SHELL is not set
CONFIG_KERNEL_SHELL=y
CONFIG_KERNEL_THREAD_SHELL=y
