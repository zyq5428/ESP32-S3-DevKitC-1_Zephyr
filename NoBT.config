CONFIG_COMPILER_CODEGEN_VLIW_AUTO=y
# CONFIG_COMPILER_CODEGEN_VLIW_ENABLED is not set
# CONFIG_COMPILER_CODEGEN_VLIW_DISABLED is not set
# end of Code Generation
# end of Compiler Options

# CONFIG_ASSERT_ON_ERRORS is not set
# CONFIG_NO_RUNTIME_CHECKS is not set
CONFIG_RUNTIME_ERROR_CHECKS=y

#
# Build Options
