CONFIG_SHELL_DEFAULT_TERMINAL_HEIGHT=24
CONFIG_SHELL_ARGC_MAX=20
CONFIG_SHELL_TAB=y
CONFIG_SHELL_TAB_AUTOCOMPLETION=y
CONFIG_SHELL_ASCII_FILTER=y
CONFIG_SHELL_WILDCARD=y
CONFIG_SHELL_MSG_CMD_NOT_FOUND=y
